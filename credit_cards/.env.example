# ─── Database ───────────────────────────────────────────────────────────────
# Supabase connection string (Transaction mode, port 6543 for serverless)
# Format: postgresql+asyncpg://[user]:[password]@[host]:[port]/[db]?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Google Sheets ──────────────────────────────────────────────────────────
# Path to the service account JSON credentials file
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── App ────────────────────────────────────────────────────────────────────
# Set to "production" in prod; anything else is treated as development
APP_ENV=development

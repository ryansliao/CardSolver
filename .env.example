# ─── Database ───────────────────────────────────────────────────────────────
# Supabase connection string (Session mode, port 5432)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Google Sheets ──────────────────────────────────────────────────────────
# "oauth" (default) — browser login, no key file needed
# "service_account" — service account JSON key (for servers/CI)
GOOGLE_AUTH_METHOD=oauth

# Path to the downloaded OAuth client secret JSON (place it in secrets/)
GOOGLE_CLIENT_SECRETS_FILE=secrets/client_secret_YOUR_ID.apps.googleusercontent.com.json
# OAuth token cache — written automatically after first login
GOOGLE_TOKEN_PATH=secrets/.oauth_token.json

# Service account alternative (only needed when GOOGLE_AUTH_METHOD=service_account)
# GOOGLE_CREDENTIALS_PATH=secrets/service_account.json

# ─── Google Sheet ───────────────────────────────────────────────────────────
# Filled in automatically by scripts/create_sheet.py
SPREADSHEET_ID=
SHEET_NAME=Credit Card Tool

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development

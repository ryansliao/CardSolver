# ─── Database ────────────────────────────────────────────────────────────────
# Azure Database for PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://[USERNAME]:[PASSWORD]@[SERVER].postgres.database.azure.com:5432/postgres?ssl=require

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (defaults to localhost:5173 in dev)
# In production set this to your Azure Static Web App or App Service URL
ALLOWED_ORIGINS=http://localhost:5173
